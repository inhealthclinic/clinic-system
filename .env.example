# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# WhatsApp через Green-API (используется в проде)
GREENAPI_INSTANCE_ID=
GREENAPI_API_TOKEN=
GREENAPI_WEBHOOK_TOKEN=your-webhook-secret
# Опционально — кастомный хост Green-API (по умолчанию api.green-api.com)
# GREENAPI_API_URL=

# SMS (Twilio) — опционально, без них SMS-канал отдаёт failed,
# WhatsApp продолжает работать
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Email (Resend) — опционально
RESEND_API_KEY=

# Cron — общий секрет для /api/cron/* эндпоинтов
# Должен совпадать со значением в GitHub Secrets (CRON_SECRET)
CRON_SECRET=

# App URL — нужен для автоустановки webhook Green-API
NEXT_PUBLIC_APP_URL=https://your-domain.kz
